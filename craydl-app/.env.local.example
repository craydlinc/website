# Copy to .env.local (never commit .env.local)

# HubSpot → Settings → Integrations → Private Apps → Create → token (see docs/HUBSPOT_PRIVATE_APP_SETUP.md)
HUBSPOT_PRIVATE_APP_TOKEN=

# Your tracking script portal ID (same as js.hs-scripts.com/XXXXX.js)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=47055408

# Internal name of contact property "CLIENT TYPE" (Settings → Properties → Contact → CLIENT TYPE)
# Default is client_type — change only if yours differs (e.g. client_type_123)
HUBSPOT_CLIENT_TYPE_PROPERTY=client_type
